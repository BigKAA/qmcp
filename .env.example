# QDrant Configuration
QDRANT_URL=http://192.168.218.190:6333
QDRANT_API_KEY=

# Embedding Model
# Default embedding model - used when not specified per-collection.
# Can be overridden using model= parameter in qdrant_index_directory() or qdrant_reindex()
# Recommended models:
#   - Code search: jinaai/jina-embeddings-v2-base-code (768 dim)
#   - Lightweight: BAAI/bge-small-en-v1.5 (384 dim)
#   - Multilingual KB: intfloat/multilingual-e5-large (1024 dim, requires prefixes)
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Embedding Model Cache Directory
# Persist downloaded models across restarts. If not set, uses system temp.
# Models are 7MB-2.2GB depending on which one you use.
# Example: /home/user/.cache/fastembed
# EMBEDDING_CACHE_DIR=/path/to/cache

# Server Configuration
HOST=0.0.0.0
PORT=8000
TRANSPORT=streamable-http

# Indexer Configuration
BATCH_SIZE=50
DEBOUNCE_SECONDS=5

# Watch Configuration (comma-separated for multiple paths)
WATCH_PATHS=/data/repo,/data/docs

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=text
