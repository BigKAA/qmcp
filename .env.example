# QDrant Configuration
QDRANT_URL=http://192.168.218.190:6333
QDRANT_API_KEY=

# Embedding Model
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Server Configuration
HOST=0.0.0.0
PORT=8000
TRANSPORT=streamable-http

# Indexer Configuration
BATCH_SIZE=50
DEBOUNCE_SECONDS=5

# Watch Configuration (comma-separated for multiple paths)
WATCH_PATHS=/data/repo,/data/docs

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=text
